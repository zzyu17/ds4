#!/usr/bin/env bash
set -euo pipefail

DS4_DIR="$(cd "$(dirname "$0")/.." && pwd)"
DS4_SERVER="$DS4_DIR/ds4-server"

MODEL="${DS4_SERVER_MODEL:-q4}"
PORT="${DS4_SERVER_PORT:-17353}"
HOST="${DS4_SERVER_HOST:-0.0.0.0}"
CTX="${DS4_SERVER_CTX:-262144}"
THREADS="${DS4_SERVER_THREADS:-}"
QUALITY="${DS4_SERVER_QUALITY:-0}"
WARM="${DS4_SERVER_WARM:-0}"
KV_DISK_DIR="${DS4_SERVER_KV_DISK_DIR:-}"
KV_DISK_SPACE_MB="${DS4_SERVER_KV_DISK_SPACE_MB:-8192}"
TRACE="${DS4_SERVER_TRACE:-}"
LOG_DIR="${DS4_SERVER_LOG_DIR:-$HOME/.ollama/logs}"
LOG="$LOG_DIR/ds4-server.log"
PIDFILE="$LOG_DIR/ds4-server.pid"
MAX_ROT="${DS4_SERVER_LOG_ROTATIONS:-5}"

usage() {
  cat <<USAGE
Usage: $(basename "$0") [-m model] [-p port] [-c ctx] [-t threads] [-w] [-q] [-h]

Options:
  -m  MODEL     GGUF model path or alias (default: q4)
  -p  PORT      Server port (default: 17353)
  -c  CTX       Context size (default: 262144)
  -t  THREADS   CPU threads (default: auto)
  -w            Enable warm-weights (slower startup, fewer first-use stalls)
  -q            Enable quality mode (default: off)
  -h            Show this help

Environment variables: DS4_SERVER_MODEL, DS4_SERVER_PORT, DS4_SERVER_HOST,
  DS4_SERVER_CTX, DS4_SERVER_THREADS, DS4_SERVER_QUALITY, DS4_SERVER_WARM,
  DS4_SERVER_KV_DISK_DIR, DS4_SERVER_KV_DISK_SPACE_MB, DS4_SERVER_TRACE,
  DS4_SERVER_LOG_DIR, DS4_SERVER_LOG_ROTATIONS
USAGE
}

term() {
  python3 - "$1" <<'PY2'
import os,sys
os.kill(int(sys.argv[1]),9)
PY2
}

alive() {
  python3 - "$1" <<'PY2'
import os,sys
try: os.kill(int(sys.argv[1]),0)
except OSError: raise SystemExit(1)
PY2
}

while getopts ":m:p:c:t:wqh" opt; do
  case "$opt" in
    m) MODEL="$OPTARG" ;;
    p) PORT="$OPTARG" ;;
    c) CTX="$OPTARG" ;;
    t) THREADS="$OPTARG" ;;
    w) WARM=1 ;;
    q) QUALITY=1 ;;
    h) usage; exit 0 ;;
    :) echo "Missing: -$OPTARG" >&2; exit 2 ;;
    \?) echo "Unknown: -$OPTARG" >&2; usage >&2; exit 2 ;;
  esac
done
shift $((OPTIND - 1))

# --- alias resolution ---
ALIAS_FILE="$(dirname "$0")/model-aliases.json"
if [[ -f "$ALIAS_FILE" ]]; then
  resolved=$(python3 - "$MODEL" "$ALIAS_FILE" <<'PY3'
import json, sys, os
model = sys.argv[1]
alias_file = sys.argv[2]
if os.path.exists(model):
    print(model)
    sys.exit(0)
with open(alias_file) as f:
    aliases = json.load(f)
resolved = aliases.get(model, "")
if resolved and os.path.exists(resolved):
    print(resolved)
else:
    print("")
PY3
  )
  if [[ -n "$resolved" ]]; then
    echo "[alias] $MODEL -> $resolved" >&2
    MODEL="$resolved"
  elif [[ ! -f "$MODEL" ]]; then
    echo "Error: model not found: $MODEL (not a file path, not a known alias)" >&2
    echo "Known aliases:" >&2
    python3 - "$ALIAS_FILE" <<'PY4' >&2
import json, sys
with open(sys.argv[1]) as f:
    aliases = json.load(f)
for k, v in aliases.items():
    if not k.startswith("$"):
        print(f"  {k} -> {v}")
PY4
    exit 1
  fi
fi

mkdir -p "$LOG_DIR"
if [[ -f "$PIDFILE" ]]; then
  old=$(cat "$PIDFILE" 2>/dev/null || true)
  [[ -n "$old" ]] && alive "$old" && term "$old"
fi
for p in $(lsof -tiTCP:"$PORT" -sTCP:LISTEN 2>/dev/null || true); do term "$p"; done

if [[ -f "$LOG" && -s "$LOG" ]]; then
  for ((i=MAX_ROT;i>=1;i--)); do
    [[ -e "${LOG_DIR}/ds4-server-${i}.log" ]] && { (( i == MAX_ROT )) && rm -f "${LOG_DIR}/ds4-server-${i}.log" || mv -f "${LOG_DIR}/ds4-server-${i}.log" "${LOG_DIR}/ds4-server-$((i+1)).log"; }
  done
  mv -f "$LOG" "${LOG_DIR}/ds4-server-1.log"
fi

# Build extra args
EXTRA_ARGS=()
[[ "$QUALITY" == "1" ]] && EXTRA_ARGS+=(--quality)
[[ "$WARM" == "1" ]] && EXTRA_ARGS+=(--warm-weights)
[[ -n "$THREADS" ]] && EXTRA_ARGS+=(-t "$THREADS")
[[ -n "$KV_DISK_DIR" ]] && EXTRA_ARGS+=(--kv-disk-dir "$KV_DISK_DIR" --kv-disk-space-mb "$KV_DISK_SPACE_MB")
[[ -n "$TRACE" ]] && EXTRA_ARGS+=(--trace "$TRACE")

cd "$DS4_DIR"
nohup ./ds4-server \
  -m "$MODEL" \
  --port "$PORT" \
  --host "$HOST" \
  --ctx "$CTX" \
  ${EXTRA_ARGS:+"${EXTRA_ARGS[@]}"} \
  > "$LOG" 2>&1 < /dev/null &

echo $! > "$PIDFILE"
echo "started pid=$! port=$PORT ctx=$CTX quality=$QUALITY warm=$WARM model=$MODEL log=$LOG"
